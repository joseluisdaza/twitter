# ──────────────────────────────────────────────
# Node.js / TypeScript
# ──────────────────────────────────────────────
node_modules/

# ──────────────────────────────────────────────
# CDK (infrastructure/)
# ──────────────────────────────────────────────

# TypeScript compilados — solo dentro de infrastructure
infrastructure/**/*.js
!infrastructure/jest.config.js
infrastructure/**/*.d.ts

# CDK staging y outputs
.cdk.staging
cdk.out

# ──────────────────────────────────────────────
# Smithy
# ──────────────────────────────────────────────

# Gradle build output (artefactos de compilación Java/Gradle)
smithy/build/

# Gradle cache local (creado al correr ./gradlew)
smithy/.gradle/

# Gradle wrapper JAR (binario descargado, no debe commitearse)
smithy/gradle/wrapper/gradle-wrapper.jar

# Código TypeScript generado por Smithy (se regenera con ./gradlew build)
# Cliente: smithy/generated/source/typescript-client-codegen/
# Servidor: smithy/generated/source/typescript-server-codegen/
smithy/generated/
