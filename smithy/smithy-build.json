{
  "version": "1.0",
  "outputDirectory": "generated",
  "sources": [
    "model"
  ],
  "plugins": {
    "build-info": {
      "version": "1.0.0",
      "sdkId": "Chirp"
    },

    "typescript-client-codegen": {
      "package": "@chirp/client",
      "packageVersion": "0.0.1",
      "packageDescription": "Client SDK for the Chirp API (generated by Smithy)",
      "packageJson": {
        "license": "MIT",
        "author": "Chirp Team"
      }
    },

    "typescript-server-codegen": {
      "package": "@chirp/server",
      "packageVersion": "0.0.1",
      "packageDescription": "Server SDK for the Chirp API (generated by Smithy)",
      "packageJson": {
        "license": "MIT",
        "author": "Chirp Team"
      },
      "disableDefaultValidation": true
    }
  }
}