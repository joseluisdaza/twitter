# Copia este archivo a .env y rellena tus valores reales.
# El archivo .env NUNCA debe commitearse al repositorio.

# ── AWS ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=TU_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1

# ── Git ──────────────────────────────────────────────────
GIT_USER_NAME=Tu Nombre Completo
GIT_USER_EMAIL=tu@email.com

# GitHub Personal Access Token (para hacer push via HTTPS)
# Crear en: https://github.com/settings/tokens
# Scopes necesarios: repo
GITHUB_TOKEN=TU_GITHUB_TOKEN
