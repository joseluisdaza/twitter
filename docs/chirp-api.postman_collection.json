{
  "info": {
    "name": "Chirp API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://wdpadf9z7j.execute-api.us-east-1.amazonaws.com" },
    { "key": "token",   "value": "" },
    { "key": "userId",  "value": "" },
    { "key": "userId2", "value": "" },
    { "key": "chirpId", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register User 1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Test1234\",\n  \"username\": \"alice\",\n  \"displayName\": \"Alice\"\n}" }
          }
        },
        {
          "name": "Register User 2",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"Test1234\",\n  \"username\": \"bob\",\n  \"displayName\": \"Bob\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.accessToken) { pm.collectionVariables.set('token', r.accessToken); }",
            "if (r.userId)      { pm.collectionVariables.set('userId', r.userId); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Test1234\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "2. Chirps",
      "item": [
        {
          "name": "Create Chirp",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.chirpId) { pm.collectionVariables.set('chirpId', r.chirpId); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/chirps",
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hello from Chirp! This is my first post.\"\n}" }
          }
        },
        {
          "name": "Get Chirp",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chirps/{{chirpId}}"
          }
        },
        {
          "name": "Like Chirp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chirps/{{chirpId}}/like",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Get Chirp Likes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chirps/{{chirpId}}/likes"
          }
        },
        {
          "name": "Unlike Chirp",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chirps/{{chirpId}}/like"
          }
        },
        {
          "name": "Hide Chirp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chirps/{{chirpId}}/hide",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Get User Chirps",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/chirps"
          }
        },
        {
          "name": "Delete Chirp",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chirps/{{chirpId}}"
          }
        }
      ]
    },
    {
      "name": "3. Comments",
      "item": [
        {
          "name": "Create Comment",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.commentId) { pm.collectionVariables.set('commentId', r.commentId); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/chirps/{{chirpId}}/comments",
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Great post!\"\n}" }
          }
        },
        {
          "name": "Get Chirp Comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chirps/{{chirpId}}/comments"
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chirps/{{chirpId}}/comments/{{commentId}}"
          }
        }
      ]
    },
    {
      "name": "4. Users",
      "item": [
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Get User by Username",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/by-username/alice"
          }
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "body": { "mode": "raw", "raw": "{\n  \"displayName\": \"Alice Updated\",\n  \"bio\": \"Developer at Chirp\"\n}" }
          }
        },
        {
          "name": "Get User Likes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/likes"
          }
        }
      ]
    },
    {
      "name": "5. Follows",
      "item": [
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId2}}/follow",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Get Followers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId2}}/followers"
          }
        },
        {
          "name": "Get Following",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/following"
          }
        },
        {
          "name": "Get Timeline",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/timeline"
          }
        },
        {
          "name": "Unfollow User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId2}}/follow"
          }
        }
      ]
    }
  ]
}
